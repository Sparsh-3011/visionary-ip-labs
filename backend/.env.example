# MongoDB Configuration
MONGO_URL="mongodb://localhost:27017"
# For MongoDB Atlas (cloud), use connection string like:
# MONGO_URL="mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority"

# Database Name
DB_NAME="visionary_ip_labs"

# CORS - Comma-separated origins
CORS_ORIGINS="http://localhost:3000"
# For production, use your actual domain:
# CORS_ORIGINS="https://visionaryiplabs.com,https://www.visionaryiplabs.com"

# Google Sheets OAuth Configuration (Optional)
# Get these from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8001/api/applications/oauth/sheets/callback"
# For production:
# GOOGLE_REDIRECT_URI="https://yourbackend.com/api/applications/oauth/sheets/callback"

# Google Spreadsheet ID
# Get from spreadsheet URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID_HERE/edit
GOOGLE_SPREADSHEET_ID=""
